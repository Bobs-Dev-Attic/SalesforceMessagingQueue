<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>EXAMPLE consumer object. Holds an address to geocode and the result returned by the U.S. Census Geocoder, enqueued through Message_Queue__c. When a match is written, a record-triggered flow runs post-processing.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Geocode Request</label>
    <nameField>
        <displayFormat>GEO-{00000000}</displayFormat>
        <label>Geocode Request Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Geocode Requests</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
